{
  "name": "mindmap-lite",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "pnpm run build && vite preview",
    "deploy": "pnpm run build && wrangler deploy",
    "test": "vitest run",
    "migrate": "wrangler d1 migrations apply mindmap-lite-db --local",
    "migrate:remote": "wrangler d1 migrations apply mindmap-lite-db --remote",
    "generate": "drizzle-kit generate",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@hono/inertia": "^0.2.0",
    "@hono/oauth-providers": "^0.8.5",
    "@inertiajs/core": "^3.0.3",
    "@inertiajs/react": "^3.3.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.21",
    "konva": "^10.2.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.2.3",
    "@cloudflare/workers-types": "^4.20250214.0",
    "@tailwindcss/vite": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.0.9",
    "typescript": "^5.8.3",
    "vite": "^8.0.10",
    "vite-ssr-components": "^0.6.1",
    "vitest": "^4.1.1",
    "wrangler": "^4.17.0"
  }
}
