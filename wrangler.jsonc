{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "edane",
  "main": "./app/server.ts",
  "compatibility_date": "2025-08-03",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "mindmap-lite-db",
      "database_id": "aeb23f2c-ead6-4495-854b-dfec9fef53ae"
    }
  ],
  "r2_buckets": [
    {
      "binding": "IMAGES",
      "bucket_name": "edane-images"
    }
  ]
}
